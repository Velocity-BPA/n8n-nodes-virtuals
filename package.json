{
  "name": "n8n-nodes-virtuals",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Virtuals Protocol AI agent token ecosystem providing 6 resources and 40+ operations for agent management, G.A.M.E. framework, token trading, and social integrations.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-virtuals.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-virtuals#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-virtuals/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "virtuals",
    "virtuals-protocol",
    "ai-agents",
    "game-framework",
    "base-chain",
    "web3",
    "blockchain",
    "defi",
    "token-trading",
    "autonomous-agents"
  ],
  "main": "dist/nodes/Virtuals/Virtuals.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/VirtualsApi.credentials.js",
      "dist/credentials/VirtualsWallet.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Virtuals/Virtuals.node.js",
      "dist/nodes/Virtuals/VirtualsTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "axios": "^1.6.2",
    "ethers": "^6.9.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.4",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.22.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
